# Salin file ini jadi `.env` lalu isi value sesuai environment lo.
# `.env` di-ignore oleh git — JANGAN commit kredensial asli.

# ─── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Uncomment kalau collector butuh auth (mis. Grafana Tempo cloud):
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Basic <your-base64-token>

OTEL_SERVICE_NAME=solace-go-consumer
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# ─── Solace Broker ────────────────────────────────────────────────────────────
SOLACE_BROKER_URL=tcp://localhost:55554
SOLACE_VPN=default
SOLACE_USERNAME=default
SOLACE_PASSWORD=changeme
SOLACE_QUEUE=demo-queue
